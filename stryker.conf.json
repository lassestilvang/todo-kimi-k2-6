{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "jest",
  "testRunner_comment": "Jest test runner is used for mutation testing",
  "mutate": [
    "src/lib/actions/tasks.ts",
    "src/lib/db/driver.ts",
    "src/lib/validation.ts"
  ],
  "coverageAnalysis": "perTest",
  "jestOptions": ["--config", "jest.config.js"],
  "timeoutMS": 60000,
  "concurrency": 1,
  "sandbox": ["prompter"]
}